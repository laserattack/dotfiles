# ================ README


# What is it : script for xbps cache management
# Usage      : xbps-cache [OPTION]...

# Flags:
#   -h, --help           Show this help message
#   -v, --verbose        Detailed output
#   -c, --clean N        Keep only N latest versions of each package, remove the rest
#   -s, --show PKG       Show info about specific package
#   -S, --show-all       Show all packages in cache
#   -C, --cache-dir DIR  Specify cache directory (/var/cache/xbps by default)


use strict;
use warnings;
use version;
use File::Spec;
use feature 'say';
use Getopt::Long qw\:config bundling\;

my $CACHE_DIR_DEFAULT = "/var/cache/xbps";

# flags

my $HELP      = 0;
my $VERBOSE   = 0;
my $SHOW_ALL  = 0;
my $SHOW_PKG  = 0;
my $CLEAN     = 0;
my $CACHE_DIR = undef;

sub usage {
    say 'What is it : script for xbps cache management';
    say 'Usage      : xbps-cache [OPTION]...';
    say '';
    say 'Flags:';
    say '  -h, --help           Show this help message';
    say '  -v, --verbose        Detailed output';
    say '  -c, --clean N        Keep only N latest versions of each package, remove the rest';
    say '  -s, --show PKG       Show info about specific package';
    say '  -S, --show-all       Show all packages in cache';
    say "  -C, --cache-dir DIR  Specify cache directory ($CACHE_DIR_DEFAULT by default)";
    say '';
    say 'READ IT PLS BRO: Versions are determined by file modification time (mtime),';
    say '      reflecting download order, not semantic version numbers.';
    say '      Because different packages use different version formats:';
    say '        - Standard:     1.2.3_4, 2.77_1';
    say '        - Date-based:   2026.03.01_1, 20250212_3';
    say '        - Complex:      190600.20161030_6, 14.2.1+20250405_4';
    say '        - With letters: 1.0.0.alpha_5, 0.1.20251104_1';
    say '        - ...';
    say '      Parsing all these formats reliably is extremely complex and unreliable.';
    say '';
    say '*********************************************************************';
    say 'WARNING: If you copy or restore packages from backup, mtime will change!';
    say '        This means the "latest" version detection may be incorrect.';
    say '        IN THIS CASE, THE USE OF THE SCRIPT IS NOT RECOMMENDED!!!';
    say '*********************************************************************';

    exit 0;
}

sub get_cache_info {
    my ($cache_dir) = @_;

    my %cache_info;

    # get all packages
    opendir(my $dh, $cache_dir) or die "ERROR: Cannot open cache dir '$cache_dir': $!\n";

    while (my $file_name = readdir($dh)) {
        next unless $file_name =~ /\.xbps$/; # skip if not a package

        my $full_path = File::Spec->catfile($cache_dir, $file_name);
        next unless -f $full_path; # skip if not a file

        # say $full_path;

        if ($file_name =~ /^(.*)-(.*)\.([^\.]+)\.xbps$/) {
            my ($pkg_name, $pkg_vers, $pkg_arch) = ($1, $2, $3);

            push @{$cache_info{$pkg_name}}, {
                path  => $full_path,
                vers  => $pkg_vers,
                arch  => $pkg_arch,
                mtime => (stat($full_path))[9],
            };
        }
    }

    closedir($dh) or die "ERROR: Cannot close cache dir '$cache_dir': $!\n";

    return \%cache_info;
}

sub show_pkg {
    my ($cache_info, $pkg_name, $verbose) = @_;
    my $versions = $cache_info->{$pkg_name};
    my $versions_count = scalar @$versions;

    unless ($verbose) {
        say "$pkg_name ($versions_count)";
    } else {

        say "=" x 60;
        say "Package: $pkg_name";
        say "Total versions: $versions_count";
        say "=" x 60;

        my @sorted = sort { $a->{mtime} <=> $b->{mtime} } @$versions;
        for my $i (0 .. $#sorted) {
            my $pkg = $sorted[$i];
            my $num = $i + 1;
            printf "  [%3d] Version:  %s\n", $num, $pkg->{vers};
            printf "        Arch:     %s\n", $pkg->{arch};
            printf "        Path:     %s\n", $pkg->{path};
        }
    }
}

sub show_all {
    my ($cache_info, $verbose) = @_;

    foreach my $pkg_name (keys %$cache_info) {
        show_pkg($cache_info, $pkg_name, $verbose);
    }
}

sub clean_all {
    my ($cache_info, $keep_count, $verbose) = @_;

    foreach my $pkg_name (keys %$cache_info) {
        my $versions = $cache_info->{$pkg_name};

        # New ones first
        my @sorted = sort { $b->{mtime} <=> $a->{mtime} } @$versions;

        if (scalar @sorted > $keep_count) {
            for my $i ($keep_count .. $#sorted) {
                my $pkg  = $sorted[$i];
                my $xbps = $pkg->{path};
                my $sig  = "$xbps.sig";
                my $sig2 = "$xbps.sig2";
                
                say "INFO: Deleting: $pkg_name $pkg->{vers}" if $verbose;
                unlink $xbps, $sig, $sig2;
                unless (-f $xbps || -f $sig || -f $sig2) {
                    say "INFO: $pkg_name $pkg->{vers} was deleted" if $verbose;
                } else {
                    warn "WARNING: Some files still exist for $pkg_name $pkg->{vers}\n";
                }
            }
        }
    }
}

sub main {
    # checks
    die "ERROR: Directory '$CACHE_DIR' does not exist\n" unless -d $CACHE_DIR;

    # information
    my $cache_info     = get_cache_info($CACHE_DIR);
    my $total_packages = scalar keys %$cache_info;
    my $total_files    = 0;
    $total_files       += scalar @{$_} for values %$cache_info;

    # check: ls -la /var/cache/xbps/*.xbps 2>/dev/null | wc -l
    if ($VERBOSE) {
        say "INFO: Cache directory:        $CACHE_DIR"      if $VERBOSE;
        say "INFO: Total unique packages:  $total_packages" if $VERBOSE;
        say "INFO: Total cached files:     $total_files"    if $VERBOSE;
    }

    # logic

    show_all($cache_info, $VERBOSE) if $SHOW_ALL;

    if ($SHOW_PKG) {
        if (exists $cache_info->{$SHOW_PKG}) {
            show_pkg($cache_info, $SHOW_PKG, $VERBOSE);
        } else {
            die "ERROR: Package '$SHOW_PKG' not found in cache\n";
        }
    }

    clean_all($cache_info, $CLEAN, $VERBOSE) if $CLEAN;

}

GetOptions(
    'help|h'        => \$HELP,
    'verbose|v'     => \$VERBOSE,
    'show-all|S'    => \$SHOW_ALL,
    'show|s=s'      => \$SHOW_PKG,
    'cache-dir|C=s' => \$CACHE_DIR,
    'clean|c=i'     => \$CLEAN,
) or die 'ERROR: Invalid command line options\n';

usage() if $HELP;

$CACHE_DIR = $CACHE_DIR_DEFAULT unless $CACHE_DIR;

if ($> != 0 && $CLEAN) {
    warn "WARNING: Running without root privileges. Are you sure you have the rights to clean cache?\n";
}

main()
