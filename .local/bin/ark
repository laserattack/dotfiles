#!/usr/bin/env perl

use strict;
use warnings;
use feature 'say';
use File::Spec;
use File::Path 'make_path';
use File::Basename qw\dirname basename\;
use Getopt::Long qw\:config bundling\;

my $BACKUP_LIST_DEFAULT = "$ENV{HOME}/.ark/list";
my $BACKUP_PATH_DEFAULT = "$ENV{HOME}/.ark/bak";

# flags

my $HELP        = 0;
my $TAR         = 0;
my $BACKUP_LIST = '';
my $BACKUP_PATH = '';

sub check_command {
    my ($cmd) = @_;
    my @paths = split(':', $ENV{PATH} || '/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin');
    foreach my $path (@paths) {
        my $full_path = "$path/$cmd";
        return $full_path if -x $full_path;
    }
    return;
}

sub usage {
    say "ark - simple and dirty script for making backups";
    say "Usage: ark [-lpth]";
    say "";
    say "Flags:";
    say "  -l, --list FILE   Backup list file (default: '$BACKUP_LIST_DEFAULT')";
    say "  -p, --path DIR    Backup dir path (default: '$BACKUP_PATH_DEFAULT')";
    say "  -t, --tar         Create tar archive from backup directory";
    say "                    and put it near backup dir";
    say "  -h, --help        This help";
    say "";
    say "RSYNC AND TAR ARE REQUIRED!!!!";
    say "";
    say "Backup list file example:";
    say "  # exclude patterns";
    say "  !buildroot";
    say "  ";
    say "  # add in backup (absolute paths!!)";
    say "  ~/projects";
    say "  ~/software";
    say "  ~/3dparty";
    say "  ~/.ai_key";
    say "  ~/.ark/list";
    say "  ~/.bash_history";
    say "  ~/.z";
    exit 0;
}

sub create_backup {
    eval { make_path($BACKUP_PATH); };
    die "ERROR: Cannot create path '$BACKUP_PATH': $@" if $@;
    die "ERROR: '$BACKUP_PATH' is not a directory" unless -d $BACKUP_PATH;

    my @paths;
    my @exclude;

    open my $fh, '<', $BACKUP_LIST or die "ERROR: Cannot open '$BACKUP_LIST': $!";
    while (my $src_path = <$fh>) {
        chomp $src_path;
        next if $src_path =~ /^\s*#/;

        $src_path =~ s/^\s+|\s+$//g;
        
        if ($src_path =~ /^!\s*(.+)$/) {
            my $pattern = $1;
            if ($pattern) {
                push @exclude, $pattern;
                say "Exclude pattern: $pattern";
            }
            next;
        }
        
        $src_path =~ s/^~/$ENV{HOME}/;
        next unless $src_path;
        
        if (-e $src_path) {
            push @paths, $src_path;
            say "Will be synchronized: $src_path";
        } else {
            warn "WARNING: '$src_path' does not exist";
        }
    }
    close $fh or warn "WARNING: Error closing '$BACKUP_LIST': $!";

    die "ERROR: No paths to backup found in '$BACKUP_LIST'" unless @paths;

    my @cmd = ('rsync', '-avxR', '--delete');
    push @cmd, map { "--exclude=$_" } @exclude;
    push @cmd, '--progress';
    push @cmd, @paths;
    push @cmd, "$BACKUP_PATH/";
    
    say "Starting backup...";
    my $cmd_string = join ' ', map { $_ =~ /[\s]/ ? "'$_'" : $_ } @cmd;
    say "Running: $cmd_string";
    
    system(@cmd);
    my $exit_code = $? >> 8;
    die "rsync failed with exit code $exit_code" if $exit_code != 0;
    
    say "Backup completed: $BACKUP_PATH";

    if ($TAR) {
        my $tar_path   = $BACKUP_PATH . '.tar';
        my $parent_dir = dirname($BACKUP_PATH);
        my $bak_name   = basename($BACKUP_PATH);

        my @tar_cmd = ('tar', '-cf', $tar_path, '--xattrs', '-C', $parent_dir, $bak_name);
        my $cmd_string = join ' ', map { $_ =~ /[\s]/ ? "'$_'" : $_ } @tar_cmd;
        say "Running tar: $cmd_string";
        system(@tar_cmd);
        my $tar_exit = $? >> 8;
        die "ERROR: Failed to create tar archive" if $tar_exit != 0;
    }
}

GetOptions(
        'list|l=s'  => \$BACKUP_LIST,
        'path|p=s'  => \$BACKUP_PATH,
        'tar|t'     => \$TAR,
        'help|h'    => \$HELP
    ) or die "ERROR: Invalid command line options\n";

usage() if $HELP;

die "Download 'rsync' dude, plss"         if !check_command('rsync');
die "You dont have 'tar' program?? Wtf??" if $TAR && !check_command('tar');

$BACKUP_LIST = $BACKUP_LIST_DEFAULT unless $BACKUP_LIST;
$BACKUP_PATH = $BACKUP_PATH_DEFAULT unless $BACKUP_PATH;

create_backup();
