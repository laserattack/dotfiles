# only one chains process can run at a time

sub acquire_lock {
    if (-f $LOCKFILE) {
        open my $fh, '<', $LOCKFILE or die color("ERROR:", 31)." Cannot read lockfile: $!\n";
        my $pid = <$fh>;
        close $fh or die color("ERROR:", 31)." Cannot close lockfile: $!\n";
        if (kill(0, $pid)) {
            die color("ERROR:", 31)." Another chains process (PID $pid) is already running\n";
        } else {
            warn color("WARNING:", 33)." Removing stale lockfile from dead process $pid\n";
            die color("ERROR:", 31)." Can't remove stale lockfile\n" unless unlink $LOCKFILE;
        }
    }

    open my $fh, '>', $LOCKFILE or die color("ERROR:", 31)." Cannot create lockfile: $!\n";
    print $fh $$;
    close $fh or die color("ERROR:", 31)." Cannot close lockfile: $!\n";

    $LOCK_ACQUIRE = 1;
}

sub release_lock {
    if ($LOCK_ACQUIRE && -f $LOCKFILE) {
        die color("ERROR:", 31)." Can't remove lockfile\n" unless unlink $LOCKFILE;
        $LOCK_ACQUIRE = 0;
    }
}

sub go_ahead {
    if ($NO)  { say "n"; return 0; }
    if ($YES) { say "y"; return 1; }

    chomp(my $input = <STDIN>);
    $input =~ s/^\s+|\s+$//g;
    $input = lc($input);

    return 1 if $input eq '';
    return $input =~ /^(y|yes|yas)$/ ? 1 : 0;
}

sub suppress_output {
    my $code = shift;

    open my $oldout, '>&', \*STDOUT or die color("ERROR:", 31)." Can't dup STDOUT: $!\n";
    open my $olderr, '>&', \*STDERR or die color("ERROR:", 31)." Can't dup STDERR: $!\n";

    open STDOUT, '>', '/dev/null' or die color("ERROR:", 31)." Can't redirect STDOUT: $!\n";
    open STDERR, '>', '/dev/null' or die color("ERROR:", 31)." Can't redirect STDERR: $!\n";

    my @ret = $code->();

    open STDOUT, '>&', $oldout or die color("ERROR:", 31)." Can't restore STDOUT: $!\n";
    open STDERR, '>&', $olderr or die color("ERROR:", 31)." Can't restore STDERR: $!\n";

    close $oldout or die color("ERROR:", 31)." Can't close stdout descriptor: $!\n";
    close $olderr or die color("ERROR:", 31)." Can't close stderr descriptor: $!\n";

    return wantarray ? @ret : $ret[0];
}

sub verify_permissions {
    my ($path) = @_;
    die color("ERROR:", 31)." no permissions to read '$path'\n" unless -r $path;
    die color("ERROR:", 31)." no permissions to write to '$path'\n" unless -w $path;
}

sub verify_dir {
    my ($path) = @_;
    unless (-d $path) {
        say color("INFO:", 32)." '$path' is not a dir";
        print color("INFO:", 32)." Try to create '$path'? [Y/n] ";
        die color("ERROR:", 31)." Cannot proceed without directory '$path'\n" unless go_ahead();
        eval { make_path($path); };
        die color("ERROR:", 31)." Cannot create path '$path': $@\n" if $@;
        die color("ERROR:", 31)." '$path' is not a valid dir\n" unless -d $path;
    }
    verify_permissions($path);
}

sub verify_file {
    my ($path) = @_;
    verify_dir(dirname($path)); # verify parent dir
    unless (-f $path) {
        say color("INFO:", 32)." '$path' is not a file";
        print color("INFO:", 32)." Try to create '$path'? [Y/n] ";
        die color("ERROR:", 31)." Cannot proceed without file '$path'\n" unless go_ahead();
        eval {
            open my $fh, '>', $path or die color("ERROR:", 31)." Cannot create file: $!\n";
            close $fh or die color("ERROR:", 31)." Cannot close file: $!\n";
        };
        die color("ERROR:", 31)." Cannot create file '$path': $@\n" if $@;
        die color("ERROR:", 31)." '$path' is not a valid file\n" unless -f $path;
    }
    verify_permissions($path);
}

sub get_chains_structure {
    my ($backups_dir) = @_;

    my @chains_structure = ();

    # get all chains dirs
    opendir(my $dh, $backups_dir) or die color("ERROR:", 31)." Cannot open dir '$backups_dir': $!\n";
    my @chains = grep { -d "$backups_dir/$_" && /^since_$TIMESTAMP_FORMAT$/ } readdir($dh);
    closedir($dh) or die color("ERROR:", 31)." Cannot close dir '$backups_dir': $!\n";

    # sort chains: new ones first
    @chains = sort { $b cmp $a } @chains;

    foreach my $chain (@chains) {
        my $chain_dir = File::Spec->catdir($backups_dir, $chain);
        my @backups = ();

        # get all backups in chain
        opendir(my $dh2, $chain_dir) or die color("ERROR:", 31)." Cannot open chain dir '$chain_dir': $!\n";
        @backups = grep { /^$TIMESTAMP_FORMAT\.tar\.gz$/ } readdir($dh2);
        closedir($dh2) or die color("ERROR:", 31)." Cannot close chain dir '$chain_dir': $!\n";

        # sort backups in chain: old ones first (the order of restoration)
        @backups = sort { $a cmp $b } @backups;

        push @chains_structure, [ $chain, \@backups ];
    }

    return \@chains_structure;
}

sub format_bytes {
    my ($bytes) = @_;
    my @units   = ('B', 'K', 'M', 'G', 'T', 'P');

    return "0 B" if $bytes == 0;

    my $unit = 0;
    my $size = $bytes;

    while ($size >= 1024 && $unit < $#units) {
        $size /= 1024;
        $unit++;
    }

    if ($unit == 0) {
        # for bytes
        return sprintf("%d%s", $size, $units[$unit]);
    } else {
        # everything except bytes
        return sprintf("%.2f%s", $size, $units[$unit]);
    }
}

sub print_chains_structure {
    my ($backups_dir) = @_;
    my $chains_structure = get_chains_structure($backups_dir);

    for (my $i = @$chains_structure; $i-- > 0;) {
        my ($chain_name, $backups) = @{$chains_structure->[$i]};
        my $backups_count = $#$backups + 1;

        my $chain_size = 0;
        foreach my $backup_name (@$backups) {
            my $backup_path = File::Spec->catfile($backups_dir, $chain_name, $backup_name);
            my $size = -s $backup_path;
            $chain_size += $size if defined $size;
        }
        my $chain_size_str = format_bytes($chain_size);

        say "┌─ Chain: $chain_name [COUNT $backups_count, SIZE $chain_size_str]";

        foreach my $j (0 .. $backups_count - 1) {
            my $backup_name = $backups->[$j];
            my $prefix = $j == $backups_count - 1 ? "└──" : "├──";
            my $backup_info = $j == 0 ? "FUL " : "INC ";

            my $backup_path = File::Spec->catfile($backups_dir, $chain_name, $backup_name);
            my $backup_size = -s $backup_path;
            $backup_info = $backup_size ? $backup_info.format_bytes($backup_size) : '??';
            say "$prefix $backup_name [$backup_info]";
        }

        say "" if $i > 0;
    }
}

sub find_chain_and_backup {
    my ($chains_structure, $target_timestamp) = @_;

    my $target_chain_name    = undef;
    my $target_chain_backups = undef;
    my $target_index         = -1;

    if ($target_timestamp eq 'latest') {
        my ($chain_name, $backups) = @{$chains_structure->[0]};
        return ($chain_name, $backups, $#{$backups});
    }

    foreach my $chain_ref (@$chains_structure) {
        my ($chain_name, $backups) = @$chain_ref;

        foreach my $i (0 .. $#$backups) {
            my $backup      = $backups->[$i];
            my ($timestamp) = $backup =~ /^($TIMESTAMP_FORMAT)\.tar\.gz$/;

            if ($timestamp eq $target_timestamp) {
                return ($chain_name, $backups, $i);
            }
        }
    }

    return (undef, undef, -1);
}

# extract ONE archive
sub extract {
    my ($src, $dest) = @_;

    die color("ERROR:", 31)." File '$src' not found\n" unless -f $src;
    verify_dir($dest);

    my $tar = check_command('tar');
    die color("ERROR:", 31)." 'tar' program is required, but not found in PATH\n" unless $tar;

    say color("INFO:", 32)." Extracting '$src'";

    my $flags = $VERBOSE ? '-vxzf' : '-xzf';
    my @cmd = ($tar, '--xattrs', $flags, $src, '-C', $dest);

    $VERBOSE ? system(@cmd) : suppress_output(sub { system(@cmd) });
    my $exitcode = ($? >> 8);

    die color("ERROR:", 31)." Extract failed with exit code: $exitcode\n" if $exitcode;
}

# restoring a part of the chain to timestamp
sub restore_subchain {
    my ($backups_dir, $restore_dir) = @_;
    my $chains_structure = get_chains_structure($backups_dir);

    my ($target_chain_name, $target_chain_backups, $target_index) = find_chain_and_backup($chains_structure, $RECOVER);

    die color("ERROR:", 31)." No backup found with timestamp: $RECOVER\n" unless defined $target_chain_name;

    foreach my $i (0 .. $target_index) {
        my $backup_name = $target_chain_backups->[$i];
        my $backup_path = File::Spec->catfile($backups_dir, $target_chain_name, $backup_name);
        extract($backup_path, $restore_dir);
    }

    say color("INFO:", 32)." Restored state '$RECOVER' to " . getcwd();
}

sub verify {
    my ($path) = @_;
    die color("ERROR:", 31)." File '$path' not found\n" unless -f $path;

    my $tar = check_command('tar');
    die color("ERROR:", 31)." 'tar' program is required, but not found in PATH\n" unless $tar;

    say color("INFO:", 32)." Verifying '$path'";

    my $flags = $VERBOSE ? '-vtzf' : '-tzf';
    my @cmd = ($tar, $flags, $path);

    $VERBOSE ? system(@cmd) : suppress_output(sub { system(@cmd) });

    my $exitcode = ($? >> 8);

    die color("ERROR:", 31)." Verification of '$path' failed with exit code: $exitcode. " .
        "Maybe you should delete this archive\n" unless $exitcode == 0;
    say color("INFO:", 32)." Verification successful for '$path'";
}


# Parse verification string - either TIMESTAMP or TIMESTAMP:TIMESTAMP format
# TIMESTAMP: YYMMDDTHHMMSS | latest
sub verify_subchain {
    my ($backups_dir)    = @_;
    my $chains_structure = get_chains_structure($backups_dir);

    my ($start_timestamp, $end_timestamp) = (undef, undef);

    # validation of the fact that there is either $timestamp or $timestamp:$timestamp during flag processing
    ($start_timestamp, $end_timestamp) = ($VERIFY =~ /:/) ? split(/:/, $VERIFY) : (undef, $VERIFY);

    my ($start_chain_name, $start_chain_backups, $start_index) = (undef, undef, 0);
    my ($end_chain_name, $end_chain_backups, $end_index)       = find_chain_and_backup($chains_structure, $end_timestamp);
    die color("ERROR:", 31)." No backup found with timestamp: $end_timestamp\n" unless $end_chain_name;

    if ($start_timestamp) {
        ($start_chain_name, $start_chain_backups, $start_index) = find_chain_and_backup($chains_structure, $start_timestamp);
        die color("ERROR:", 31)." No backup found with timestamp: $start_timestamp\n" unless $start_chain_name;
        die color("ERROR:", 31)." Start and end timestamps must be from the same chain\n" if $start_chain_name ne $end_chain_name;
    }

    foreach my $i ($start_index .. $end_index) {
        my $backup_name = $end_chain_backups->[$i];
        my $backup_path = File::Spec->catfile($backups_dir, $end_chain_name, $backup_name);
        verify($backup_path);
    }

    if ($start_timestamp) {
        say color("INFO:", 32)." Chain verification successful from $start_timestamp to $end_timestamp";
    } else {
        say color("INFO:", 32)." Chain verification successful up to timestamp: $VERIFY";
    }
}

sub make_backup {
    my ($info) = @_;

    my $snar_file             = $info->{snar_file};
    my $include_paths_file    = $info->{include_paths_file};
    my $exclude_patterns_file = $info->{exclude_patterns_file};
    my $backup_file           = $info->{backup_file};

    my $snar_file_backup = "$snar_file.bak";

    if (-f $snar_file) {
        copy($snar_file, $snar_file_backup) or die color("ERROR:", 31)." Cannot back up $snar_file: $!\n";
        say color("INFO:", 32)." Metadata file '$snar_file' was backed up";
    }

    my $tar = check_command('tar');
    die color("ERROR:", 31)." 'tar' program is required, but not found in PATH\n" unless $tar;

    my $flags = $VERBOSE ? '-vg' : '-g';
    my @tar_command = ($tar, $flags, $snar_file,
                       '--one-file-system', '--xattrs',
                       '--exclude-from', $exclude_patterns_file);

    push @tar_command, '--no-check-device' if $NO_CHECK_DEVICE;

    push @tar_command, '--files-from', $include_paths_file, '-czf', $backup_file;

    my $tar_command_string = join ' ', map { $_ =~ /[\s]/ ? "'$_'" : $_ } @tar_command;
    say color("INFO:", 32)." Tar command: $tar_command_string";

    $VERBOSE ? system(@tar_command) : suppress_output(sub { system(@tar_command) });

    # ================ FROM info tar ================
    #    Possible exit codes of GNU ‘tar’ are summarized in the following
    # table:

    # 0
    #      ‘Successful termination’.

    # 1
    #      ‘Some files differ’.  If tar was invoked with ‘--compare’
    #      (‘--diff’, ‘-d’) command line option, this means that some files in
    #      the archive differ from their disk counterparts (*note compare::).
    #      If tar was given ‘--create’, ‘--append’ or ‘--update’ option, this
    #      exit code means that some files were changed while being archived
    #      and so the resulting archive does not contain the exact copy of the
    #      file set.

    # 2
    #      ‘Fatal error’.  This means that some fatal, unrecoverable error
    #      occurred.

    my $exitcode = ($? >> 8);
    if ($exitcode == 0 || $exitcode == 1) {
        if (-z $backup_file) {
            warn color("WARNING:", 33)." Backup '$backup_file' is empty (interrupted?)\n";

            # restore snar file
            if (copy($snar_file_backup, $snar_file)) {
                say color("INFO:", 32)." Metadata file '$snar_file' was restored";
            } else {
                warn color("ERROR:", 31)." Cannot restore metadata file '$snar_file': $!\n"
            }

            # delete empty archive
            say color("INFO:", 32)." Deleting empty archive '$backup_file'";
            unlink $backup_file or die color("ERROR:", 31)." Could not delete empty archive: $backup_file\n" if -f $backup_file;

            # DIE
            die color("INFO:", 32)." Empty archive was deleted\n"
        } else {
            # good exitcode (0/1) and not empty archive

            say color("INFO:", 32)." Backup '$backup_file' completed (exitcode: $exitcode)" if $exitcode == 0;
            say color("INFO:", 32)." Backup '$backup_file' completed with changed files (exitcode: $exitcode)" if $exitcode == 1;
            # GOOD
        }
    } elsif ($exitcode == 2) {
        warn color("ERROR:", 31)." Backup '$backup_file' failed (exitcode: $exitcode)\n";

        # restore snar file
        if (copy($snar_file_backup, $snar_file)) {
            say color("INFO:", 32)." Metadata file '$snar_file' was restored";
        } else {
            warn color("ERROR:", 31)." Cannot restore metadata file '$snar_file': $!\n"
        }

        # delete incomplete archive
        say color("INFO:", 32)." Deleting incomplete archive '$backup_file'";
        unlink $backup_file or die color("ERROR:", 31)." Could not delete incomplete archive: $backup_file\n" if -f $backup_file;
        die color("INFO:", 32)." Incomplete archive was deleted\n";
        # DIE
    } else {
        say color("ERROR:", 31)." unexpected exitcode: $exitcode. WTF???";

        # restore snar file !!!
        copy($snar_file_backup, $snar_file) or die color("ERROR:", 31)." Cannot restore metadata file '$snar_file': $!\n";
        die color("INFO:", 32)." Metadata file '$snar_file' was restored\n";
        # DIE
    }

    if (-f $backup_file) {
        say color("INFO:", 32)." Always verify your backups!";
        say color("INFO:", 32)." A successful exit code (0) from tar does not guarantee the backup is valid";
        say color("INFO:", 32)." For example, if the program execution was interrupted (by you or for any other reason)";
        say color("INFO:", 32)." You can verify backups using 'chains -w ...'";
    }
}

sub byebye {
    my $msg = shift(@_);
    say $msg if $msg;
    release_lock();
    exit 0;
}

sub main {

    # ==== PREPARE STRUCT ====

    # check and create if no exists
    verify_dir($MAIN_DIR);
    say color("INFO:", 32)." Main dir: $MAIN_DIR";

    # check and create if no exists
    my $include_paths_file = File::Spec->catfile($MAIN_DIR, 'include_paths.txt');
    verify_file($include_paths_file);
    say color("INFO:", 32)." Include paths file: $include_paths_file";

    # check and create if no exists
    my $exclude_patterns_file = File::Spec->catfile($MAIN_DIR, 'exclude_patterns.txt');
    verify_file($exclude_patterns_file);
    say color("INFO:", 32)." Exclude patterns file: $exclude_patterns_file";

    # check and create if no exists
    my $backups_dir = File::Spec->catdir($MAIN_DIR, 'chains');
    verify_dir($backups_dir);
    say color("INFO:", 32)." Backups dir: $backups_dir";


    # ==== SOME STUFF FOR GRACEFUL SHUTDOWN ====

    acquire_lock();

    # https://perldoc.perl.org/perlmod#BEGIN%2C-UNITCHECK%2C-CHECK%2C-INIT-and-END
    # An END code block is executed as late as possible, that is, after perl has
    # finished running the program and just before the interpreter is being exited,
    # even if it is exiting as a result of a die() function.
    # (But not if it's morphing into another program via exec, or being blown out of
    # the water by a signal--you have to trap that yourself (if you can).)
    END { byebye(); }

    # Not strictly necessary (tar handles signals itself), but kept for safety
    $SIG{'HUP'}  = 'IGNORE';
    $SIG{'INT'}  = sub { byebye(color("INFO:", 32) . " chains was sent INT signal... cleaning up"); };
    $SIG{'QUIT'} = sub { byebye(color("INFO:", 32) . " chains was sent QUIT signal... cleaning up"); };
    $SIG{'ABRT'} = sub { byebye(color("INFO:", 32) . " chains was sent ABRT signal... cleaning up"); };
    $SIG{'TERM'} = sub { byebye(color("INFO:", 32) . " chains was sent TERM signal... cleaning up"); };

    # ==== MAIN LOGIC ====

    print_chains_structure($backups_dir) if $PRINT;

    # ==== VERIFY SUBCHAIN ====
    verify_subchain($backups_dir) if $VERIFY;

    # ==== RESTORE STATE ====
    restore_subchain($backups_dir, '.') if $RECOVER;

    # ==== MAKE BACKUP ====
    if ($FULL || $INCREMENTAL) {
        # otherwise, it will make a backup of current dir (pwd)
        die color("ERROR:", 31)." Include file '$include_paths_file' is empty\n" if -z $include_paths_file;

        # only absolute paths in include_paths_file
        open my $fh, '<', $include_paths_file or die color("ERROR:", 31)." Cannot open file: $!\n";
        while (my $line = <$fh>) {
            chomp $line;
            next if $line =~ /^\s*$/; # empty lines are OK
            die color("ERROR:", 31)." Only absolute paths should be in '$include_paths_file'\n" unless $line =~ /^\//;
        }
        close $fh or die color("ERROR:", 31)." Cannot close file: $!\n";

        my $timestamp = strftime("%y%m%dT%H%M%S", localtime);
        my $backup_dir;

        if ($FULL) {

            # a chain of incremental backups in a timestamped folder
            # full backup = first backup in chain

            $backup_dir = File::Spec->catdir($backups_dir, 'since_'.$timestamp);
            die color("ERROR:", 31)." '$backup_dir' already exists\n" if -d $backup_dir;
            verify_dir($backup_dir);
            say color("INFO:", 32)." Creating new backup chain in: $backup_dir";

        } elsif ($INCREMENTAL) {

            # incremental backup = backup to latest backup chain

            # try found latest backup chain
            my $chains_structure = get_chains_structure($backups_dir);
            my $last_chain_name = @$chains_structure ? $chains_structure->[0]->[0] : undef;
            $backup_dir = $last_chain_name ? File::Spec->catdir($backups_dir, $last_chain_name) : undef;

            die color("ERROR:", 31)." No existing backup chain found in '$backups_dir'. Use -f (--full) first\n" unless $backup_dir;
        }

        # tar will create it itself if no exists
        my $snar_file = File::Spec->catfile($backup_dir, 'incremental.snar');
        say color("INFO:", 32)." Metadata file: $snar_file";
        my $backup_file = File::Spec->catfile($backup_dir, "${timestamp}.tar.gz");

        die color("ERROR:", 31)." Backup file '$backup_file' already exists\n" if -f $backup_file;

        my $info = {
            snar_file             => $snar_file,
            include_paths_file    => $include_paths_file,
            exclude_patterns_file => $exclude_patterns_file,
            backup_file           => $backup_file,
        };

        make_backup($info);
    } # if ($FULL || $INCREMENTAL)
}

init_color();

GetOptions(
        'help|h'             => \$HELP,
        'yes|y'              => \$YES,
        'no|n'               => \$NO,
        'main-directory|m=s' => \$MAIN_DIR,
        'no-check-device'    => \$NO_CHECK_DEVICE,
        'incremental|i'      => \$INCREMENTAL,
        'full|f'             => \$FULL,
        'recover|r'          => sub { $RECOVER = 'latest' },
        'verify|w'           => sub { $VERIFY  = 'latest' },
        'directory|C=s'      => \$DIR,
        'print|p'            => \$PRINT,
        'verbose|v'          => \$VERBOSE,
    ) or die color("ERROR:", 31)." Invalid command line options\n";

usage() if $HELP;

if (defined $DIR) {
    say color("INFO:", 32)." Changing directory to: $DIR";
    verify_dir($DIR);
    chdir $DIR or die color("ERROR:", 31)." Cannot change to directory '$DIR': $!\n";
    say color("INFO:", 32)." Now in: " . getcwd();
}

if ($RECOVER) {
    my $timestamp = shift @ARGV;

    if (!defined $timestamp) {
    } elsif ($timestamp =~ /^$TIMESTAMP_FORMAT$/) {
        $RECOVER = $timestamp;
    } else {
        unshift @ARGV, $timestamp;
    }
    say color("INFO:", 32)." Recovering state: $RECOVER";
}

if ($VERIFY) {
    my $timestamp_pattern = qr/(?:$TIMESTAMP_FORMAT|latest)/;
    my $range             = shift @ARGV;

    if (!defined $range) {
    } elsif ($range =~ /^($timestamp_pattern)$/) {
        $VERIFY = $1;
    } elsif ($range =~ /^($timestamp_pattern):($timestamp_pattern)$/) {
        $VERIFY = $1.':'.$2;
    } elsif ($range =~ /^:($timestamp_pattern)$/) {
        $VERIFY = $1;
    } elsif ($range =~ /^($timestamp_pattern):$/) {
        $VERIFY = $1.':latest';
    } elsif ($range =~ /^:$/) {
        $VERIFY = 'latest:latest';
    } else {
        unshift @ARGV, $range;
    }
    say color("INFO:", 32)." Verify chain mode: $VERIFY";
}

$MAIN_DIR = $MAIN_DIR_DEFAULT unless $MAIN_DIR;
$LOCKFILE = File::Spec->catfile($MAIN_DIR, 'chains.lock');

main()
