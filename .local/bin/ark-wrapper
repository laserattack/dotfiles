#!/usr/bin/env bash

if pgrep -f 'perl.*ark'; then
    notify-send -t 3000 'ARK BACKUP' 'Already running'
else
    notify-send -t 3000 'ARK BACKUP' 'Starting backup...'
    if $HOME/.local/bin/ark; then
        notify-send -t 3000 'ARK BACKUP' 'Done'
    else
        notify-send -t 3000 'ARK BACKUP' 'Failed'
    fi
fi
