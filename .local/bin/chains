sub go_ahead {
    if ($NO)  { say "n"; return 0; }
    if ($YES) { say "y"; return 1; }

    chomp(my $input = <STDIN>);
    $input =~ s/^\s+|\s+$//g;
    $input = lc($input);

    return 1 if $input eq '';
    return $input =~ /^(y|yes|yas)$/ ? 1 : 0;
}

sub suppress_output {
    my $code = shift;

    open my $oldout, '>&', \*STDOUT or log_error("Can't dup STDOUT: $!");
    open my $olderr, '>&', \*STDERR or log_error("Can't dup STDERR: $!");

    open STDOUT, '>', '/dev/null' or log_error("Can't redirect STDOUT: $!");
    open STDERR, '>', '/dev/null' or log_error("Can't redirect STDERR: $!");

    my @ret = $code->();

    open STDOUT, '>&', $oldout or log_error("Can't restore STDOUT: $!");
    open STDERR, '>&', $olderr or log_error("Can't restore STDERR: $!");

    close $oldout or log_error("Can't close stdout descriptor: $!");
    close $olderr or log_error("Can't close stderr descriptor: $!");

    return wantarray ? @ret : $ret[0];
}

sub verify_permissions {
    my ($path) = @_;
    log_error("No permissions to read '$path'") unless -r $path;
    log_error("No permissions to write to '$path'") unless -w $path;
}

sub verify_dir {
    my ($path) = @_;
    unless (-d $path) {
        log_info("'$path' is not a dir");
        print color("INF:", 32)." Try to create '$path'? [Y/n] ";
        log_error("Cannot proceed without directory '$path'") unless go_ahead();
        eval { make_path($path); };
        log_error("Cannot create path '$path': $@") if $@;
        log_error("'$path' is not a valid dir") unless -d $path;
    }
    verify_permissions($path);
}

sub verify_file {
    my ($path) = @_;
    verify_dir(dirname($path)); # verify parent dir
    unless (-f $path) {
        log_info("'$path' is not a file");
        print color("INF:", 32)." Try to create '$path'? [Y/n] ";
        log_error("Cannot proceed without file '$path'") unless go_ahead();
        eval {
            open my $fh, '>', $path or log_error("Cannot create file: $!");
            close $fh or log_error("Cannot close file: $!");
        };
        log_error("Cannot create file '$path': $@") if $@;
        log_error("'$path' is not a valid file") unless -f $path;
    }
    verify_permissions($path);
}

sub get_chains_structure {
    my ($backups_dir) = @_;

    my @chains_structure = ();

    # get all chains dirs
    # TODO(20260410T175126): add similar repeating blocks to the function
    opendir(my $dh, $backups_dir) or log_error("Cannot open dir '$backups_dir': $!");
    my @chains = grep { -d "$backups_dir/$_" && /^since_$TIMESTAMP_FORMAT$/ } readdir($dh);
    closedir($dh) or log_error("Cannot close dir '$backups_dir': $!");

    # sort chains: new ones first
    @chains = sort { $b cmp $a } @chains;

    foreach my $chain (@chains) {
        my $chain_dir = File::Spec->catdir($backups_dir, $chain);
        my @backups = ();

        # get all backups in chain
        opendir(my $dh2, $chain_dir) or log_error("Cannot open chain dir '$chain_dir': $!");
        @backups = grep { /^$TIMESTAMP_FORMAT\.tar\.gz$/ } readdir($dh2);
        closedir($dh2) or log_error("Cannot close chain dir '$chain_dir': $!");

        # sort backups in chain: old ones first (the order of restoration)
        @backups = sort { $a cmp $b } @backups;

        push @chains_structure, [ $chain, \@backups ];
    }

    return \@chains_structure;
}

sub format_bytes {
    my ($bytes) = @_;
    my @units   = ('B', 'K', 'M', 'G', 'T', 'P');

    return "0B" if $bytes == 0;

    my $unit = 0;
    my $size = $bytes;

    while ($size >= 1024 && $unit < $#units) {
        $size /= 1024;
        $unit++;
    }

    if ($unit == 0) {
        # for bytes
        return sprintf("%d%s", $size, $units[$unit]);
    } else {
        # everything except bytes
        return sprintf("%.2f%s", $size, $units[$unit]);
    }
}

sub print_chains_structure {
    my ($backups_dir) = @_;
    my $chains_structure = get_chains_structure($backups_dir);

    for (my $i = @$chains_structure; $i-- > 0;) {
        my ($chain_name, $backups) = @{$chains_structure->[$i]};
        my $backups_count = $#$backups + 1;

        my $chain_size = 0;
        foreach my $backup_name (@$backups) {
            my $backup_path = File::Spec->catfile($backups_dir, $chain_name, $backup_name);
            my $size = -s $backup_path;
            $chain_size += $size if defined $size;
        }
        my $chain_size_str = format_bytes($chain_size);

        if ($backups_count) {
            say "┌─ Chain: $chain_name [COUNT $backups_count, SIZE $chain_size_str]";
        } else {
            say "── Chain: $chain_name [COUNT $backups_count, SIZE $chain_size_str]";
        }

        foreach my $j (0 .. $backups_count - 1) {
            my $backup_name = $backups->[$j];
            my $prefix = $j == $backups_count - 1 ? "└──" : "├──";
            my $backup_info = $j == 0 ? "FUL " : "INC ";

            my $backup_path = File::Spec->catfile($backups_dir, $chain_name, $backup_name);
            my $backup_size = -s $backup_path;
            $backup_info = $backup_size ? $backup_info.format_bytes($backup_size) : '??';
            say "$prefix $backup_name [$backup_info]";
        }

        say "" if $i > 0;
    }
}

sub find_chain_and_backup {
    my ($chains_structure, $target_timestamp) = @_;

    my $target_chain_name    = undef;
    my $target_chain_backups = undef;
    my $target_index         = -1;

    if ($target_timestamp eq 'latest') {
        my ($chain_name, $backups) = @{$chains_structure->[0]};
        return ($chain_name, $backups, $#{$backups});
    }

    foreach my $chain_ref (@$chains_structure) {
        my ($chain_name, $backups) = @$chain_ref;

        foreach my $i (0 .. $#$backups) {
            my $backup      = $backups->[$i];
            my ($timestamp) = $backup =~ /^($TIMESTAMP_FORMAT)\.tar\.gz$/;
            return ($chain_name, $backups, $i) if $timestamp eq $target_timestamp;
        }
    }

    return (undef, undef, -1);
}

# extract ONE archive
sub extract {
    my ($src, $dest) = @_;

    log_error("File '$src' not found") unless -f $src;
    verify_dir($dest);

    my $tar = check_command('tar');
    log_error("'tar' program is required, but not found in PATH") unless $tar;

    log_info("Extracting '$src'");

    my $flags = $VERBOSE ? '-vxzf' : '-xzf';
    my @cmd = ($tar, '--xattrs', $flags, $src, '-C', $dest);

    $VERBOSE ? system(@cmd) : suppress_output(sub { system(@cmd) });
    my $exitcode = ($? >> 8);

    log_error("Extract failed with exit code: $exitcode") if $exitcode;
}

# restoring a part of the chain to timestamp
sub restore_subchain {
    my ($backups_dir, $restore_dir) = @_;
    my $chains_structure = get_chains_structure($backups_dir);

    my ($target_chain_name, $target_chain_backups, $target_index) = find_chain_and_backup($chains_structure, $RECOVER);

    log_error("No backup found with timestamp: $RECOVER") unless defined $target_chain_name;

    foreach my $i (0 .. $target_index) {
        my $backup_name = $target_chain_backups->[$i];
        my $backup_path = File::Spec->catfile($backups_dir, $target_chain_name, $backup_name);
        extract($backup_path, $restore_dir);
    }

    log_info("Restored state '$RECOVER' to " . getcwd());
}

sub verify {
    my ($path) = @_;
    log_error("File '$path' not found") unless -f $path;

    my $tar = check_command('tar');
    log_error("'tar' program is required, but not found in PATH") unless $tar;

    log_info("Verifying '$path'");

    my $flags = $VERBOSE ? '-vtzf' : '-tzf';
    my @cmd = ($tar, $flags, $path);

    $VERBOSE ? system(@cmd) : suppress_output(sub { system(@cmd) });

    my $exitcode = ($? >> 8);

    log_error("Verification of '$path' failed with exit code: $exitcode. " .
              "Maybe you should delete this archive") unless $exitcode == 0;
    log_info("Verification successful for '$path'");
}


# Parse verification string - either TIMESTAMP or TIMESTAMP:TIMESTAMP format
# TIMESTAMP: YYMMDDTHHMMSS | latest
sub verify_subchain {
    my ($backups_dir)    = @_;
    my $chains_structure = get_chains_structure($backups_dir);

    my ($start_timestamp, $end_timestamp)                      = (undef, undef);
    my ($start_chain_name, $start_chain_backups, $start_index) = (undef, undef, 0);
    my ($end_chain_name, $end_chain_backups, $end_index)       = (undef, undef, -1);

    # validation of the fact that there is either $timestamp or $timestamp:$timestamp during flag processing
    ($start_timestamp, $end_timestamp) = ($VERIFY =~ /:/) ? split(/:/, $VERIFY) : (undef, $VERIFY);

    if (!$start_timestamp) {
        # Case 1: single timestamp or "latest"
        ($end_chain_name, $end_chain_backups, $end_index) = find_chain_and_backup($chains_structure, $end_timestamp);
        log_error("No backup found with timestamp: $end_timestamp") unless $end_chain_name;
        foreach my $i ($start_index .. $end_index) {
            my $backup_name = $end_chain_backups->[$i];
            my $backup_path = File::Spec->catfile($backups_dir, $end_chain_name, $backup_name);
            verify($backup_path);
        }
        log_info("Chain verification successful up to timestamp: $end_timestamp");
        return;
    } else {
        # Case 2: range

        # Find start backup first
        ($start_chain_name, $start_chain_backups, $start_index) = find_chain_and_backup($chains_structure, $start_timestamp);
        log_error("No backup found with timestamp: $start_timestamp") unless $start_chain_name;

        if ($end_timestamp eq 'latest') {
            $end_index         = $#{$start_chain_backups};
            $end_chain_name    = $start_chain_name;
            $end_chain_backups = $start_chain_backups;
        } else {
            # Explicit timestamp
            ($end_chain_name, $end_chain_backups, $end_index) = find_chain_and_backup($chains_structure, $end_timestamp);
            log_error("No backup found with timestamp: $end_timestamp") unless $end_chain_name;
            log_error("Start and end timestamps must be from the same chain") if $start_chain_name ne $end_chain_name;
        }

        log_error("Start timestamp ($start_timestamp) is after end timestamp ($end_timestamp)") if $start_index > $end_index;
        foreach my $i ($start_index .. $end_index) {
            my $backup_name = $end_chain_backups->[$i];
            my $backup_path = File::Spec->catfile($backups_dir, $end_chain_name, $backup_name);
            verify($backup_path);
        }
        log_info("Chain verification successful from $start_timestamp to $end_timestamp");
    }
}

sub make_backup {
    my ($info) = @_;

    my $snar_file             = $info->{snar_file};
    my $include_paths_file    = $info->{include_paths_file};
    my $exclude_patterns_file = $info->{exclude_patterns_file};
    my $backup_file           = $info->{backup_file};

    my $snar_file_backup = "$snar_file.bak";

    if (-f $snar_file) {
        copy($snar_file, $snar_file_backup) or log_error("Cannot back up $snar_file: $!");
        log_info("Metadata file '$snar_file' was backed up");
    }

    my $tar = check_command('tar');
    log_error("'tar' program is required, but not found in PATH") unless $tar;

    my $flags = $VERBOSE ? '-vg' : '-g';
    my @tar_command = ($tar, $flags, $snar_file,
                       '--one-file-system', '--xattrs',
                       '--exclude-from', $exclude_patterns_file);

    push @tar_command, '--no-check-device' if $NO_CHECK_DEVICE;
    push @tar_command, '--files-from', $include_paths_file, '-czf', $backup_file;

    my $tar_command_string = join ' ', map { $_ =~ /[\s]/ ? "'$_'" : $_ } @tar_command;
    log_info("Tar command: $tar_command_string");

    $VERBOSE ? system(@tar_command) : suppress_output(sub { system(@tar_command) });

    # ================ FROM info tar ================
    #    Possible exit codes of GNU ‘tar’ are summarized in the following
    # table:

    # 0
    #      ‘Successful termination’.

    # 1
    #      ‘Some files differ’.  If tar was invoked with ‘--compare’
    #      (‘--diff’, ‘-d’) command line option, this means that some files in
    #      the archive differ from their disk counterparts (*note compare::).
    #      If tar was given ‘--create’, ‘--append’ or ‘--update’ option, this
    #      exit code means that some files were changed while being archived
    #      and so the resulting archive does not contain the exact copy of the
    #      file set.

    # 2
    #      ‘Fatal error’.  This means that some fatal, unrecoverable error
    #      occurred.

    my $exitcode = ($? >> 8);
    if ($exitcode == 0 || $exitcode == 1) {
        if (-z $backup_file) {
            log_warn("Backup '$backup_file' is empty (interrupted?)");

            # restore snar file
            if (copy($snar_file_backup, $snar_file)) {
                log_info("Metadata file '$snar_file' was restored");
            } else {
                log_warn("Cannot restore metadata file '$snar_file': $!");
            }

            # delete empty archive
            log_info("Deleting empty archive '$backup_file'");
            unlink $backup_file or log_error("Could not delete empty archive: $backup_file") if -f $backup_file;

            # DIE
            log_info("Empty archive was deleted");
            exit 1;
        } else {
            # good exitcode (0/1) and not empty archive

            log_info("Backup '$backup_file' completed (exitcode: $exitcode)") if $exitcode == 0;
            log_info("Backup '$backup_file' completed with changed files (exitcode: $exitcode)") if $exitcode == 1;
            # GOOD
        }
    } elsif ($exitcode == 2) {
        log_warn("Backup '$backup_file' failed (exitcode: $exitcode)");

        # restore snar file
        if (copy($snar_file_backup, $snar_file)) {
            log_info("Metadata file '$snar_file' was restored");
        } else {
            log_warn("Cannot restore metadata file '$snar_file': $!");
        }

        # delete incomplete archive
        log_info("Deleting incomplete archive '$backup_file'");
        unlink $backup_file or log_error("Could not delete incomplete archive: $backup_file") if -f $backup_file;
        log_info("Incomplete archive was deleted");
        exit 1;
        # DIE
    } else {
        log_info("Unexpected exitcode: $exitcode. WTF???");

        # restore snar file !!!
        copy($snar_file_backup, $snar_file) or log_error("Cannot restore metadata file '$snar_file': $!");
        log_info("Metadata file '$snar_file' was restored");
        exit 1;
        # DIE
    }

    if (-f $backup_file) {
        log_warn("Always verify your backups!");
        log_warn("A successful exit code (0) from tar does not guarantee the backup is valid");
        log_warn("For example, if the program execution was interrupted (by you or for any other reason)");
        log_warn("You can verify backups using 'chains -w ...'");
    }
}

sub main {

    # ==== PREPARE STRUCT ====

    # check and create if no exists
    verify_dir($MAIN_DIR);
    log_info("Main dir: $MAIN_DIR");

    # check and create if no exists
    my $include_paths_file = File::Spec->catfile($MAIN_DIR, 'include_paths.txt');
    verify_file($include_paths_file);
    log_info("Include paths file: $include_paths_file");

    # check and create if no exists
    my $exclude_patterns_file = File::Spec->catfile($MAIN_DIR, 'exclude_patterns.txt');
    verify_file($exclude_patterns_file);
    log_info("Exclude patterns file: $exclude_patterns_file");

    # check and create if no exists
    my $backups_dir = File::Spec->catdir($MAIN_DIR, 'chains');
    verify_dir($backups_dir);
    log_info("Backups dir: $backups_dir");

    # ==== MAIN LOGIC ====

    print_chains_structure($backups_dir) if $PRINT;

    # ==== VERIFY SUBCHAIN ====
    verify_subchain($backups_dir) if $VERIFY;

    # ==== RESTORE STATE ====
    restore_subchain($backups_dir, '.') if $RECOVER;

    # ==== MAKE BACKUP ====
    if ($FULL || $INCREMENTAL) {
        # otherwise, it will make a backup of current dir (pwd)
        log_error("Include file '$include_paths_file' is empty") if -z $include_paths_file;

        # only absolute paths in include_paths_file
        open my $fh, '<', $include_paths_file or log_error("Cannot open file: $!");
        while (my $line = <$fh>) {
            chomp $line;
            next if $line =~ /^\s*$/; # empty lines are OK
            log_error("Only absolute paths should be in '$include_paths_file'") unless $line =~ /^\//;
        }
        close $fh or log_error("Cannot close file: $!");

        my $timestamp = strftime($TIMESTAMP_FORMAT_STRFTIME, localtime);
        my $backup_dir;

        if ($FULL) {

            # a chain of incremental backups in a timestamped folder
            # full backup = first backup in chain

            $backup_dir = File::Spec->catdir($backups_dir, 'since_'.$timestamp);
            log_error("'$backup_dir' already exists") if -d $backup_dir;
            verify_dir($backup_dir);
            log_info("Creating new backup chain in: $backup_dir");

        } elsif ($INCREMENTAL) {

            # incremental backup = backup to latest backup chain

            # try found latest backup chain
            my $chains_structure = get_chains_structure($backups_dir);
            my $last_chain_name = @$chains_structure ? $chains_structure->[0]->[0] : undef;
            $backup_dir = $last_chain_name ? File::Spec->catdir($backups_dir, $last_chain_name) : undef;

            log_error("No existing backup chain found in '$backups_dir'. Use -f (--full) first") unless $backup_dir;
        }

        # tar will create it itself if no exists
        my $snar_file = File::Spec->catfile($backup_dir, 'incremental.snar');
        log_info("Metadata file: $snar_file");
        my $backup_file = File::Spec->catfile($backup_dir, "${timestamp}.tar.gz");

        log_error("Backup file '$backup_file' already exists") if -f $backup_file;

        my $info = {
            snar_file             => $snar_file,
            include_paths_file    => $include_paths_file,
            exclude_patterns_file => $exclude_patterns_file,
            backup_file           => $backup_file,
        };

        make_backup($info);
    } # if ($FULL || $INCREMENTAL)
}

init_color();
system('stty -echoctl 2>/dev/null');

GetOptions(
    'help|h'             => \$HELP,
    'yes|y'              => \$YES,
    'no|n'               => \$NO,
    'main-directory|m=s' => \$MAIN_DIR,
    'no-check-device'    => \$NO_CHECK_DEVICE,
    'incremental|i'      => \$INCREMENTAL,
    'full|f'             => \$FULL,
    'recover|r'          => sub { $RECOVER = 'latest' },
    'verify|w'           => sub { $VERIFY  = 'latest' },
    'directory|C=s'      => \$DIR,
    'print|p'            => \$PRINT,
    'verbose|v'          => \$VERBOSE,
) or log_error("Invalid command line options");

my $count = grep { $_ } $PRINT, $RECOVER, $VERIFY, $INCREMENTAL, $FULL;
if ($count > 1) {
    log_error("Options -p, -r, -w, -i, -f cannot be used together");
}

usage() if $HELP;

if ($> != 0 && ($FULL || $INCREMENTAL)) {
    log_warn("Running without root privileges");
    log_warn("If backing up system files, tar may fail with exit code 2");
    log_warn("Consider using: sudo chains ...");
}

if (defined $DIR) {
    log_info("Changing directory to: $DIR");
    verify_dir($DIR);
    chdir $DIR or log_error("Cannot change to directory '$DIR': $!");
    log_info("Now in: ".getcwd());
}

# latest by default
if ($RECOVER) {
    my $timestamp = shift @ARGV;

    if (!defined $timestamp) {
    } elsif ($timestamp =~ /^$TIMESTAMP_FORMAT$/) {
        $RECOVER = $timestamp;
    } else {
        unshift @ARGV, $timestamp;
    }
    log_info("Recovering state: $RECOVER");
}

# latest by default
if ($VERIFY) {
    my $timestamp_pattern = qr/(?:$TIMESTAMP_FORMAT|latest)/;
    my $range             = shift @ARGV;

    if (!defined $range) {
    } elsif ($range =~ /^($timestamp_pattern)$/) {
        $VERIFY = $1;
    } elsif ($range =~ /^($timestamp_pattern):($timestamp_pattern)$/) {
        $VERIFY = $1.':'.$2;
    } elsif ($range =~ /^:($timestamp_pattern)$/) {
        $VERIFY = $1;
    } elsif ($range =~ /^($timestamp_pattern):$/) {
        $VERIFY = $1.':latest';
    } elsif ($range =~ /^:$/) {
        $VERIFY = 'latest';
    } else {
        unshift @ARGV, $range;
    }
    log_info("Verify chain mode: $VERIFY");
}

$MAIN_DIR = $MAIN_DIR_DEFAULT unless $MAIN_DIR;

main()
