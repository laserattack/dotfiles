#!/usr/bin/env perl

# What is it : log viewer for socklog
# Usage      : murder [-hl] channel

use strict;
use warnings;
use feature 'say';
use Getopt::Long;
Getopt::Long::Configure('bundling');

my $LOG_DIR = "/var/log/socklog";

sub usage {
    say "What is it : log viewer for socklog";
    say "Usage      : sucklog [-hl] channel";
    say "";
    say "Flags:";
    say "  -h, --help  Show this help message";
    say "  -l, --list  Show list of channels";
    say "";
    say "Examples:";
    say "  sucklog kernel | tail -5";
    say "  sucklog everything | less";
}

sub main {
    my $channel = shift @ARGV;
    my $log_file = "$LOG_DIR/$channel/current";
    unless (-f $log_file) {
        say "Cannot find log file for channel '$channel'";
        exit 1;
    }
    open my $fh, '<', $log_file or do {
        say "ERROR: Cannot open $log_file: $!";
        exit 1;
    };
    print while <$fh>;
    close $fh;
}

my $HELP = 0;
my $LIST = 0;

GetOptions(
      'help|h' => \$HELP,
      'list|l' => \$LIST,
  ) or do {
      usage();
      exit 1;
};

if ($HELP) {
    usage();
    exit 0;
}

if ($LIST) {
    my @channels = map { (split '/')[-1] } grep { -d } glob("$LOG_DIR/*");
    say "$_" for @channels;
    exit 0;
}

if (@ARGV < 1) {
    usage();
    exit 1;
}

main();
