{
    "layer": "top",
    "position": "top",
    "modules-left": ["niri/workspaces"],
    "modules-center": ["clock"],
    "modules-right": ["cpu", "memory", "battery", "network", "wireplumber", "tray"],
    "clock": {
        "format": "{:%H:%M}"
    },
    "battery": {
        "format": "{capacity}%",
        "format-icons": ["", "", "", "", ""]
    }
}
