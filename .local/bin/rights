#!/usr/bin/env perl

use strict;
use warnings;
use feature 'say';

sub usage {
    say "What is it : Linux file permissions explainer";
    say "Usage      : rights PERMISSIONS";
    say "";
    say "Arguments:";
    say "  PERMISSIONS  File permissions in various formats:";
    say "               Symbolic : rwxr-xr-x, rw-------, r-x--x--x";
    say "               Numeric  : 755, 644, 777, 600, 444";
    say "";
    say "Examples:";
    say "  rights 755        Explain what 755 means";
    say "  rights rwxr-xr-x  Explain symbolic permissions";
}

sub symbolic_symbolic_perm {

}

sub explain_numeric_perm {

}

sub explain {
    my ($arg) = @_;
    if ($arg =~ /^[0-7]{3,4}$/) {
        explain_numeric_perm($arg);
    } elsif ($arg =~ /^[-dlscbp]$/) {
        explain_symbolic_perm($arg);
    } else {
        say "ERROR: Incorrect arg format";
        usage();
        exit 1;
    }
}

sub main {
    explain($_) for @ARGV;
    exit 0;
}

unless (@ARGV) {
    usage();
    exit 1;
}

main();
