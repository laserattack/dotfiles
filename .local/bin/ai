#!/usr/bin/env perl

use strict;
use warnings;
use feature 'say';
use HTTP::Tiny;
use JSON::PP;
use utf8;
binmode STDOUT, ':utf8';
binmode STDERR, ':utf8';

# you can hack it
my $url                 = 'https://openai.htk.ge/v1/chat/completions';
my $key_file            = "$ENV{HOME}/.ai_key";
my $answer_tokens_limit = 200;
my $model               = "gpt-4o";
my $system              = "Ты — терминальный ассистент. Пользователь описывает задачу на русском языке. Отвечай ТОЛЬКО bash-командой — одной строкой. Без пояснений, без markdown, без обратных кавычек. Несколько команд — через && или |. ОС: Linux.";
#

my $api_key;

sub ask {
    my $question = join(' ', @_);

    my $headers = {
        'Authorization' => "Bearer $api_key",
        'Content-Type' => 'application/json'
    };
    
    my $data = {
        model => "$model",
        messages => [
            { role => 'system', content => $system },
            { role => 'user', content => $question }
        ],
        max_tokens => $answer_tokens_limit
    };

    my $json = JSON::PP->new->utf8(1);
    my $http = HTTP::Tiny->new();
    my $response = $http->post($url, {
        headers => $headers,
        content => $json->encode($data)
    });

    if ($response->{success}) {
        my $result = $json->decode($response->{content});
        my $text = $result->{choices}[0]{message}{content};
        return $text;
    } else {
        return "Error: $response->{status} $response->{reason}";
    }    
}

sub go_ahead {
    chomp(my $input = <STDIN>);
    $input =~ s/^\s+|\s+$//g;
    $input = lc($input);

    return 1 if $input eq '';
    return $input =~ /^(y|yes|yas|д|да)$/? 1: 0;
}

sub usage {
    say "Что это       : Подсказщик bash-команд использующий AI";
    say "Использование : ai [вопрос]";
    say "";
    say "Описание:";
    say "  GPT-4o превращает описание задачи в bash-команду";
    say "  AI отвечает ТОЛЬКО командой";
    say "";
    say "ВНИМАНИЕ:";
    say "  Терминал должен поддерживать UTF-8";
    say "  Лимит по токенам ответа: $answer_tokens_limit (можно поменять в коде)";
    say "  Ключ должен быть в $key_file (можно поменять в коде)";
    say "";
    say "Примеры:";
    say "  ai показать все файлы в текущей директории";
    say "  ai найти все файлы больше 100Мб";
    say "  ai сколько свободного места на диске";
    say "  ai убить процесс на порту 3000";
}

unless (@ARGV) {
    usage();
    exit 1;
}

die "Error: API key file not found at $key_file\n" unless -f $key_file;
open my $fh, '<', $key_file or die "Error: Cannot read $key_file: $!\n";
$api_key = <$fh>;
$api_key =~ s/^\s+|\s+$//g;
close $fh;

my $answer = ask(@ARGV);
die "$answer\n" if $answer =~ /^Error:/;

say "$answer";
print "Выполнить? [Y/n] ";
if (go_ahead()) {
    system($answer);
} else {
    say "Команда не выполнена";
    exit 0;
}
